{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Garden": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=TheGarden;Username=postgres;Password=postgres"
  },
  "Simulation": {
    "TickDelayMs": 100,
    "DefaultSpeed": 5,
    "MaxSpeed": 100
  },
  "Persistence": {
    "SaveIntervalSeconds": 30,
    "AutoSave": true
  },
  "Backups": {
    "HourlyRetention": 24,
    "DailyRetention": 7,
    "WeeklyRetention": 4
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  }
}